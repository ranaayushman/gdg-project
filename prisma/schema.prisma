generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  member            Member?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Member {
  id         String   @id @default(cuid())
  accountId  String?  @unique
  name       String
  email      String   @unique
  role       String
  department String
  status     String   @default("ACTIVE")
  joinDate   DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  account    Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String   @default("N/A") // ✅ Default added
  linkedin  String?
  github    String?
  branch    String   @default("Unknown") // ✅ Default added
  year      Int      @default(2024) // ✅ Default added
  roles     Role[]
  createdAt DateTime @default(now())

  Session          Session[]
  Account          Account[]
  TechMember       TechMember[]
  PublicRelations  PublicRelations[]
  VideoEditor      VideoEditor[]
  ContentWriter    ContentWriter[]
  GraphicsDesigner GraphicsDesigner[]
  Photographer     Photographer[]
  Recruitment      Recruitment[]
}

model Role {
  id     String   @id @default(uuid())
  name   RoleType
  user   User     @relation(fields: [userId], references: [id])
  userId String
}

enum RoleType {
  TECH_MEMBER
  PR
  VIDEO_EDITOR
  CONTENT_WRITER
  GRAPHICS_DESIGNER
  PHOTOGRAPHER
}

model TechMember {
  id             String   @id @default(uuid())
  user           User     @relation(fields: [userId], references: [id])
  userId         String
  languages      String[]
  projects       String? // GitHub links
  openSource     Boolean
  hackathons     Boolean
  codingSolution String? // Optional coding answer
}

model PublicRelations {
  id          String   @id @default(uuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  socialMedia Boolean
  outreach    Boolean
  platforms   String[]
  eventPromo  String?
}

model VideoEditor {
  id           String   @id @default(uuid())
  user         User     @relation(fields: [userId], references: [id])
  userId       String
  tools        String[]
  portfolio    String?
  colorGrading Boolean
  storytelling String?
}

model ContentWriter {
  id          String  @id @default(uuid())
  user        User    @relation(fields: [userId], references: [id])
  userId      String
  articles    String?
  seo         Boolean
  socialPosts Boolean
}

model GraphicsDesigner {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  tools     String[]
  portfolio String?
  uiux      Boolean
}

model Photographer {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  skills     String[]
  liveEvents Boolean
  portfolio  String?
  camera     String?
}

model Recruitment {
  id          String  @id @default(uuid())
  fullName    String
  email       String  @unique
  phoneNumber String
  year        Int
  domain      String
  suggestion  String?
  gdgStand    String
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id])
}
